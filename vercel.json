{
  "version": 2,
  "builds": [
    {
      "src": "server/index.js",
      "use": "@vercel/node"
    },
    {
      "src": "package.json",
      "use": "@vercel/static-build",
      "config": {
        "outputDirectory": "dist"
      }
    }
  ],
  "routes": [
    { "src": "/api/(.*)", "dest": "server/index.js" },
    { "src": "/(.*)", "dest": "dist/$1" }
  ],
  "rewrites": [
    { "source": "/api/:path*", "destination": "/server/index.js" },
    { "source": "/((?!api/).*)", "destination": "/index.html" }
  ]
}
